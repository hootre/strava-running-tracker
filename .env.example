# Strava API (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=여기에_클라이언트_ID
STRAVA_CLIENT_SECRET=여기에_클라이언트_시크릿

# 앱 URL (Vercel 배포 후 자동 생성되는 URL)
BASE_URL=https://your-app.vercel.app

# 관리자 비밀번호
ADMIN_PASSWORD=여기에_강력한_비밀번호

# Vercel KV (Vercel 대시보드에서 KV 스토어 연결 시 자동 설정됨)
# KV_REST_API_URL=자동설정
# KV_REST_API_TOKEN=자동설정

# 푸시 알림 VAPID 키 (npx web-push generate-vapid-keys 로 생성)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# Vercel Cron 보안 키 (임의의 긴 문자열)
CRON_SECRET=여기에_크론_시크릿_키
