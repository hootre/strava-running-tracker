{
  "rewrites": [
    { "source": "/auth/:path*", "destination": "/api/server" },
    { "source": "/api/:path*", "destination": "/api/server" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 9 * * 4,5,6"
    }
  ]
}
